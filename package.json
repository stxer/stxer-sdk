{
  "name": "stxer",
  "version": "0.6.0",
  "license": "MIT",
  "author": "Kyle Fang",
  "repository": {
    "type": "git",
    "url": "https://github.com/stxer/stxer-sdk"
  },
  "main": "dist/index.js",
  "module": "dist/stxer.esm.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/sample",
    "!dist/sample"
  ],
  "scripts": {
    "analyze": "size-limit --why",
    "build": "dts build",
    "lint": "biome check .",
    "prepare": "dts build",
    "size": "size-limit",
    "start": "dts watch",
    "test": "dts test",
    "sample:counter": "tsx src/sample/counter.ts",
    "sample:read": "tsx src/sample/read.ts",
    "sample:instant": "tsx src/sample/instant.ts",
    "sample:failure-modes": "tsx src/sample/failure-modes.ts",
    "sample:batch-categories": "tsx src/sample/batch-categories.ts",
    "sample:verify-types": "tsx src/sample/verify-types.ts",
    "sample:vitest": "vitest run src/sample/contract-vitest.test.ts"
  },
  "husky": {
    "hooks": {
      "pre-commit": "dts lint && biome check ."
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=12"
  },
  "size-limit": [
    {
      "path": "dist/stxer.cjs.production.min.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/stxer.esm.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@size-limit/preset-small-lib": "12.1.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "25.6.0",
    "dts-cli": "^2.0.5",
    "husky": "^9.1.7",
    "size-limit": "12.1.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@stacks/network": "^7.3.1",
    "@stacks/stacks-blockchain-api-types": "^7.14.1",
    "@stacks/transactions": "7.4.0",
    "c32check": "^2.0.0",
    "clarity-abi": "^0.1.0",
    "ts-clarity": "^0.1.1"
  }
}
